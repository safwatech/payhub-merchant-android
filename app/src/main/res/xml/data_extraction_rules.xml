<?xml version="1.0" encoding="utf-8"?>
<!-- Backup is disabled (allowBackup=false) — credentials live in EncryptedSharedPreferences
     and must not leave the device. This file exists so the manifest reference resolves. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
